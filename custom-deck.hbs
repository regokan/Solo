{{!< default}}

{{#contentFor "body_class"}} is-deck{{/contentFor}}

{{#post}}
<div class="deck-ui">

    {{! Hidden source — JS parses this to build slides }}
    <div class="deck-content-source" aria-hidden="true">{{content}}</div>

    {{! Top bar }}
    <div class="deck-bar">
        <a class="deck-bar-home" href="{{@site.url}}" title="Back to site">
            {{#if @site.logo}}
                <img src="{{@site.logo}}" alt="{{@site.title}}" class="deck-bar-logo">
            {{else}}
                {{@site.title}}
            {{/if}}
        </a>
        <h1 class="deck-bar-title">{{title}}</h1>
        <div class="deck-bar-tags">
            {{#foreach tags}}
                <a class="gh-article-tag" href="{{url}}" style="--tag-color: {{accent_color}}">{{name}}</a>
            {{/foreach}}
        </div>
    </div>

    {{! Progress bar }}
    <div class="deck-progress">
        <div class="deck-progress-fill"></div>
    </div>

    {{! Slide stage }}
    <div class="deck-stage" role="region" aria-label="Presentation slides"></div>

    {{! Nav bar }}
    <div class="deck-nav">
        <button class="deck-btn deck-prev" aria-label="Previous slide" disabled>&#8592;</button>
        <span class="deck-counter">
            <span class="deck-counter-current">1</span>
            <span class="deck-counter-sep">/</span>
            <span class="deck-counter-total"></span>
        </span>
        <button class="deck-btn deck-next" aria-label="Next slide">&#8594;</button>
    </div>

</div>

<article class="gh-article deck-post-footer">

    <div class="post-footer-author">
        {{#foreach authors}}
            <a class="post-footer-avatar" href="{{url}}">
                {{#if profile_image}}
                    <img src="{{profile_image}}" alt="{{name}}">
                {{else}}
                    <div class="gh-author-icon">{{> icons/avatar}}</div>
                {{/if}}
            </a>
        {{/foreach}}
        <div class="post-footer-byline">
            <div class="post-footer-author-name">{{authors}}</div>
            <time class="gh-article-date" datetime="{{date format='YYYY-MM-DD'}}">{{date format="DD MMM YYYY"}}</time>
        </div>
        <div class="post-footer-tags">
            {{#foreach tags}}
                <a class="gh-article-tag" href="{{url}}" style="--tag-color: {{accent_color}}">{{name}}</a>
            {{/foreach}}
        </div>
    </div>

    {{#if comments}}
        <div class="gh-comments gh-canvas">
            {{comments title="" count=false}}
        </div>
    {{/if}}

    <footer class="gh-article-footer gh-canvas">
        <nav class="gh-navigation">
            <div class="gh-navigation-previous">
                {{#prev_post}}
                    <a class="gh-navigation-link" href="{{url}}">← <span class="gh-navigation-text">{{t "Previous"}}</span></a>
                {{/prev_post}}
            </div>
            <div class="gh-navigation-middle">
                <a href="#/share" class="gh-button-share">{{t "Share"}}</a>
            </div>
            <div class="gh-navigation-next">
                {{#next_post}}
                    <a class="gh-navigation-link" href="{{url}}"><span class="gh-navigation-text">{{t "Next"}}</span> →</a>
                {{/next_post}}
            </div>
        </nav>
    </footer>
</article>
{{/post}}
