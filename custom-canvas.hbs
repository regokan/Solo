{{!< default}}

{{#contentFor "body_class"}} is-canvas{{/contentFor}}

{{#post}}
<div class="canvas-ui">

    {{! Hidden source — JS finds .canvas-data inside here }}
    <div class="canvas-content-source" aria-hidden="true">{{content}}</div>

    {{! Top bar }}
    <div class="canvas-bar">
        <a class="canvas-bar-home" href="{{@site.url}}" title="Back to site">
            {{#if @site.logo}}
                <img src="{{@site.logo}}" alt="{{@site.title}}" class="canvas-bar-logo">
            {{else}}
                {{@site.title}}
            {{/if}}
        </a>
        <h1 class="canvas-bar-title">{{title}}</h1>
        <div class="canvas-bar-tags">
            {{#foreach tags}}
                <a class="gh-article-tag" href="{{url}}" style="--tag-color: {{accent_color}}">{{name}}</a>
            {{/foreach}}
        </div>
    </div>

    {{! Graph stage }}
    <div class="canvas-stage" role="region" aria-label="Graph canvas">
        <svg class="canvas-svg" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <marker id="cv-arrow" markerWidth="10" markerHeight="7"
                        refX="9" refY="3.5" orient="auto" markerUnits="strokeWidth">
                    <polygon points="0 0, 10 3.5, 0 7" fill="#777"/>
                </marker>
                <marker id="cv-arrow-rev" markerWidth="10" markerHeight="7"
                        refX="1" refY="3.5" orient="auto-start-reverse" markerUnits="strokeWidth">
                    <polygon points="0 0, 10 3.5, 0 7" fill="#777"/>
                </marker>
            </defs>
            <g class="canvas-root"></g>
        </svg>
    </div>

    {{! Zoom controls }}
    <div class="canvas-controls">
        <button class="canvas-ctrl-btn canvas-zoom-in"  aria-label="Zoom in">+</button>
        <button class="canvas-ctrl-btn canvas-zoom-out" aria-label="Zoom out">−</button>
        <button class="canvas-ctrl-btn canvas-zoom-fit" aria-label="Fit to screen" title="Fit">⊡</button>
    </div>

</div>

<article class="gh-article canvas-post-footer">
    <section class="gh-content gh-canvas">
        <aside class="gh-article-meta">
            <div class="gh-article-meta-inner">
                <div class="gh-author-image-list">
                    {{#foreach authors}}
                        <a class="gh-author-image" href="{{url}}">
                            {{#if profile_image}}
                                <img src="{{profile_image}}" alt="{{name}}">
                            {{else}}
                                <div class="gh-author-icon">{{> icons/avatar}}</div>
                            {{/if}}
                        </a>
                    {{/foreach}}
                </div>
                <div class="gh-article-meta-wrapper">
                    <div class="gh-author-name-list">{{authors}}</div>
                    <time class="gh-article-date" datetime="{{date format='YYYY-MM-DD'}}">{{date format="DD MMM YYYY"}}</time>
                </div>
                {{#foreach tags}}
                    <a class="gh-article-tag" href="{{url}}" style="--tag-color: {{accent_color}}">{{name}}</a>
                {{/foreach}}
            </div>
        </aside>
    </section>

    {{#if comments}}
        <div class="gh-comments gh-canvas">
            {{comments title="" count=false}}
        </div>
    {{/if}}

    <footer class="gh-article-footer gh-canvas">
        <nav class="gh-navigation">
            <div class="gh-navigation-previous">
                {{#prev_post}}
                    <a class="gh-navigation-link" href="{{url}}">← <span class="gh-navigation-text">{{t "Previous"}}</span></a>
                {{/prev_post}}
            </div>
            <div class="gh-navigation-middle">
                <a href="#/share" class="gh-button-share">{{t "Share"}}</a>
            </div>
            <div class="gh-navigation-next">
                {{#next_post}}
                    <a class="gh-navigation-link" href="{{url}}"><span class="gh-navigation-text">{{t "Next"}}</span> →</a>
                {{/next_post}}
            </div>
        </nav>
    </footer>
</article>
{{/post}}
